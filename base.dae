/v4l2_camera:
  ros__parameters:
    brightness: 0
    camera_frame_id: camera
    camera_info_url: ''
    contrast: 32
    hue: 0
    image_raw:
      enable_pub_plugins:
      - image_transport/raw
    image_size:
    - 640
    - 480
    output_encoding: rgb8
    pixel_format: YUYV
    qos_overrides:
      /parameter_events:
        publisher:
          depth: 1000
          durability: volatile
          history: keep_last
          reliability: reliable
    saturation: 64
    start_type_description_service: true
    use_sim_time: false
    video_device: /dev/video0
    white_balance_automatic: true

